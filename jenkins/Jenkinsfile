pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        PROJECT_DIR                  = 'CourtMetaAPI'
        CSProj                       = 'CourtMetaAPI\\CourtMetaAPI.csproj'
        CONFIGURATION                = 'Release'
        OUTPUT_DIR                   = 'publish'
        // Quiet NuGet signature verification under Jenkins service account
        NUGET_CERT_REVOCATION_MODE   = 'offline'
        DOTNET_CLI_TELEMETRY_OPTOUT  = '1'
        DOTNET_NOLOGO                = '1'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Tool Info') {
            steps {
                bat 'dotnet --info'
            }
        }

        stage('Restore') {
            steps {
                bat 'dotnet restore %CSProj%'
            }
        }

        stage('Build') {
            steps {
                bat 'dotnet build %CSProj% -c %CONFIGURATION% --no-restore'
            }
        }

        stage('Test') {
            steps {
                script {
                    // returnStatus avoids failing the step on non-zero exit
                    def rc = bat(script: 'dir /s /b *Tests.csproj 2>nul', returnStatus: true)
                    if (rc == 0) {
                        bat 'dotnet test -c %CONFIGURATION% --no-build --logger "trx;LogFileName=test-results.trx"'
                    } else {
                        echo 'No test projects found - skipping test stage.'
                    }
                }
            }
        }

        stage('Publish') {
            steps {
                bat 'dotnet publish %CSProj% -c %CONFIGURATION% -o %OUTPUT_DIR% --no-build'
            }
        }

        stage('Bundle Extension') {
            steps {
                bat '''
                    if exist %PROJECT_DIR%\\wwwroot\\court-meta-extension.zip (
                        copy /Y %PROJECT_DIR%\\wwwroot\\court-meta-extension.zip %OUTPUT_DIR%\\court-meta-extension.zip
                    )
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'publish/**/*', fingerprint: true, allowEmptyArchive: false
            }
        }
    }

    post {
        success { echo 'Court Meta CI pipeline completed successfully.' }
        failure { echo 'Court Meta CI pipeline failed - check stage logs.' }
        always  { echo "Build #${env.BUILD_NUMBER} finished with status ${currentBuild.currentResult}" }
    }
}
