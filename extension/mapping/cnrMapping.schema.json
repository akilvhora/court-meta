{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://courtmeta.local/schemas/mapping-config.json",
  "title": "Court Meta Mapping Config",
  "description": "Declarative schema validating a mapping config consumed by extension/mapping/mapper.js",
  "type": "object",
  "required": ["version", "fields"],
  "properties": {
    "$schema":     { "type": "string" },
    "version":     { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "name":        { "type": "string" },
    "description": { "type": "string" },
    "root":        { "type": "string" },
    "fields": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/definitions/spec" }
    }
  },
  "additionalProperties": false,

  "definitions": {
    "spec": {
      "type": "object",
      "required": ["rule"],
      "properties": {
        "rule": {
          "type": "string",
          "enum": [
            "exact", "regexKey", "findArray", "list", "switch",
            "literal", "combine", "coalesce", "template"
          ]
        },
        "default":    {},
        "transforms": { "$ref": "#/definitions/transforms" },

        "path":          { "type": "string" },
        "pattern":       { "type": "string" },
        "caseSensitive": { "type": "boolean" },
        "fallbackIndex": { "type": "integer", "minimum": 0 },
        "keyPattern":    { "type": "string" },
        "rowKeyPattern": { "type": "string" },
        "maxDepth":      { "type": "integer", "minimum": 0 },
        "source":        { "$ref": "#/definitions/spec" },
        "item": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/spec" }
        },
        "cases": {
          "type": "object",
          "additionalProperties": true
        },
        "value":     {},
        "sources": {
          "oneOf": [
            { "type": "array", "items": { "$ref": "#/definitions/spec" } },
            {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/spec" }
            }
          ]
        },
        "separator": { "type": "string" },
        "skipEmpty": { "type": "boolean" },
        "template":  { "type": "string" }
      },
      "allOf": [
        { "if": { "properties": { "rule": { "const": "exact"     } } }, "then": { "required": ["path"] } },
        { "if": { "properties": { "rule": { "const": "regexKey"  } } }, "then": { "required": ["pattern"] } },
        { "if": { "properties": { "rule": { "const": "switch"    } } }, "then": { "required": ["path", "cases"] } },
        { "if": { "properties": { "rule": { "const": "list"      } } }, "then": { "required": ["item"] } },
        { "if": { "properties": { "rule": { "const": "combine"   } } }, "then": { "required": ["sources"] } },
        { "if": { "properties": { "rule": { "const": "coalesce"  } } }, "then": { "required": ["sources"] } },
        { "if": { "properties": { "rule": { "const": "template"  } } }, "then": { "required": ["template", "sources"] } },
        { "if": { "properties": { "rule": { "const": "literal"   } } }, "then": { "required": ["value"] } }
      ]
    },

    "transforms": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "enum": ["trim", "upper", "lower", "nullIfEmpty", "toDate"]
          },
          {
            "type": "object",
            "required": ["fn"],
            "properties": {
              "fn":    { "type": "string", "enum": ["trim", "upper", "lower", "nullIfEmpty", "default", "toDate"] },
              "value": {}
            },
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
