{
  "$schema": "./cnrMapping.schema.json",
  "version": "1.0.0",
  "name": "ecourts.cnr.v1",
  "description": "Maps eCourts CNR API response to Court Meta refined JSON",
  "root": "data",
  "fields": {
    "cnrNumber":  { "rule": "exact", "path": "cino" },
    "caseNumber": { "rule": "exact", "path": "caseNumber" },

    "caseType": {
      "rule": "switch",
      "path": "type",
      "cases": { "filing": "Filing Case" },
      "default": "Regular Case"
    },

    "hearings": {
      "rule": "list",
      "source": {
        "rule": "findArray",
        "keyPattern": "hearr?ing",
        "rowKeyPattern": "date|purpose|judge",
        "maxDepth": 4
      },
      "item": {
        "date": {
          "rule": "regexKey",
          "pattern": "^(?!next).*(date|hearing)",
          "fallbackIndex": 0,
          "transforms": [{ "fn": "toDate" }]
        },
        "purpose": {
          "rule": "regexKey",
          "pattern": "^(?!next).*purpose",
          "fallbackIndex": 1,
          "transforms": ["trim", "nullIfEmpty"]
        },
        "judge": {
          "rule": "regexKey",
          "pattern": "judge",
          "transforms": ["trim", "nullIfEmpty"]
        },
        "business": {
          "rule": "regexKey",
          "pattern": "business",
          "transforms": ["trim", "nullIfEmpty"]
        },
        "nextDate": {
          "rule": "regexKey",
          "pattern": "next.*date",
          "transforms": [{ "fn": "toDate" }]
        },
        "nextPurpose": {
          "rule": "regexKey",
          "pattern": "next.*purpose",
          "transforms": ["trim", "nullIfEmpty"]
        }
      }
    }
  }
}
